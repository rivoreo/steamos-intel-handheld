#!/usr/bin/env bash
set -euo pipefail

action="${1:-apply}"
runtime_dir="${XDG_RUNTIME_DIR:-/run/user/$(id -u)}"
env_file="$runtime_dir/gamescope-environment"
gamescopectl="${GAMESCOPECTL:-/usr/bin/gamescopectl}"

wait_for_gamescope_environment() {
  for _ in $(seq 1 30); do
    [ -s "$env_file" ] && return 0
    sleep 0.5
  done

  echo "gamescope environment file not ready: $env_file" >&2
  return 1
}

load_gamescope_environment() {
  wait_for_gamescope_environment
  set -a
  # shellcheck disable=SC1090
  . "$env_file"
  set +a
  export XDG_RUNTIME_DIR="${XDG_RUNTIME_DIR:-$runtime_dir}"
}

apply_composite_force() {
  local apply_attempts="${GAMESCOPE_DISPLAY_APPLY_ATTEMPTS:-60}"
  local apply_interval="${GAMESCOPE_DISPLAY_APPLY_INTERVAL_SEC:-5}"
  local status=1

  load_gamescope_environment

  for attempt in $(seq 1 "$apply_attempts"); do
    if "$gamescopectl" composite_force 1; then
      echo "sent composite_force 1 (attempt $attempt/$apply_attempts)"
      status=0
    else
      status="$?"
      echo "gamescopectl composite_force 1 failed (attempt $attempt/$apply_attempts, status $status)" >&2
    fi

    [ "$attempt" -eq "$apply_attempts" ] && break
    sleep "$apply_interval"
  done

  return "$status"
}

case "$action" in
  apply)
    apply_composite_force
    ;;
  reset)
    load_gamescope_environment
    exec "$gamescopectl" composite_force 0
    ;;
  *)
    echo "Usage: $0 apply|reset" >&2
    exit 2
    ;;
esac
